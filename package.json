{
  "name": "agentsite-kit",
  "version": "1.0.2",
  "description": "CLI toolkit to make any website Agent-friendly",
  "type": "module",
  "bin": {
    "agentsite": "bin/agentsite.js"
  },
  "files": [
    "dist",
    "bin",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lingfan36/AgentSite-Kit.git"
  },
  "homepage": "https://github.com/lingfan36/AgentSite-Kit",
  "bugs": {
    "url": "https://github.com/lingfan36/AgentSite-Kit/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "agent",
    "llm",
    "ai",
    "sitemap",
    "cli",
    "web-scraper",
    "structured-data",
    "mcp",
    "llms-txt",
    "agent-friendly"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.7.0",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "fast-xml-parser": "^4.4.0",
    "fastify": "^5.0.0",
    "js-yaml": "^4.1.0",
    "minimatch": "^10.0.0",
    "ora": "^8.1.0",
    "p-limit": "^6.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsup": "^8.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}
